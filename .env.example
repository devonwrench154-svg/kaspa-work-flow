# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Airtable Personal Access Token (rotate at airtable.com/account if exposed)
# Used by api/contact.js and api/booking.js
# Set this in Vercel: Project → Settings → Environment Variables
AIRTABLE_API_KEY=your-airtable-personal-access-token-here

# Cal.com webhook secret (optional — for verifying Cal.com webhook signatures)
# Generate a random string and paste it here AND in Cal.com dashboard webhook settings
# Cal.com: Settings → Webhooks → Secret
CAL_WEBHOOK_SECRET=your-cal-webhook-secret-here

# ── Airtable table setup ────────────────────────────────────────────
# Base ID: appBqsswh4l3BAJrZ
#
# Table 1: "Kaspaflow Contact form" (existing)
#   Fields: Name, Email, Firm, Position, Desk Size,
#           Module Interest, Message, Submitted
#
# Table 2: "Kaspaflow Bookings" (create this)
#   Fields (all Single line text unless noted):
#     Name         — attendee name
#     Email        — attendee email
#     Timezone     — attendee timezone string
#     Event        — event/meeting title
#     Start Time   — ISO 8601 datetime string
#     End Time     — ISO 8601 datetime string
#     Booking UID  — Cal.com booking UID (deduplication key)
#     Source       — "Cal.com inline embed" or "Cal.com webhook — BOOKING_CREATED"
#     Logged       — ISO 8601 datetime (when the record was created)

